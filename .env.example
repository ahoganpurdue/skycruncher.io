# ─────────────────────────────────────────────────────────────────────────────
# SkyCruncher — example environment file
#
# Copy to `.env` and fill in real values. `.env` and `.env.*` are gitignored
# (this `.env.example` is the sole tracked template). NEVER commit real
# credentials. All values below are PLACEHOLDERS.
#
# Most VITE_* flags are OPTIONAL feature toggles read at build/run time — the
# app runs with sensible defaults when they are unset. The R2_* credentials are
# only needed by the operator tools that publish to Cloudflare R2 (releases,
# star-data, dashboards); the app itself never reads R2 secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Cloudflare R2 (S3-compatible) — operator/publish tooling only ────────────
# Used by tools/release/publish_app_release.mjs, tools/results/lib/r2.mjs, and
# the starplates/dashboard publishers. In practice these are loaded from a
# gitignored env-file (default src/engine/ui/dashboard/.env.r2) via --env-file,
# but they may also come from the process environment.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Optional — defaults to https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=
# Bucket names (defaults shown; override only if your buckets differ)
R2_BUCKET_APP_RELEASES=app-releases
R2_BUCKET=starplates
R2_BUCKET_THESES_DASHBOARD=theses-dashboard
# NOTE: many tools/ scripts accept additional ad-hoc R2_* knobs (budgets, dirs,
# caps, per-run tuning). Those are per-tool CLI-style params, not global config;
# see the individual tool headers under tools/.

# ── End-to-end / harness ─────────────────────────────────────────────────────
# Port the e2e wizard harnesses (tools/e2e/*) point Playwright at. Agents use a
# shared prewarmed Vite (3199); pick any free port for a standalone run.
E2E_PORT=3199

# ── Remote MCP access allowlist (tools/mcp) ──────────────────────────────────
# Comma-separated email allowlist for the Cloudflare Access JWT verifier.
# REMOTE_MCP_ACCESS_EMAILS is the primary; ACCESS_JWT_ALLOWLIST is an alternate.
# When BOTH are unset the allowlist is empty and every token FAILS CLOSED.
REMOTE_MCP_ACCESS_EMAILS=you@example.com
ACCESS_JWT_ALLOWLIST=
# Optional: pin the Access application AUD and team domain (else auto-discovered)
REMOTE_MCP_ACCESS_AUD=
REMOTE_MCP_ACCESS_TEAM=

# ── First-run sample frame (optional, honest-or-absent) ──────────────────────
# Remote URL for the "Load Sample" frame the thin client fetches when no demo
# frame is bundled. UNSET = no remote sample (falls back to a bundled /demo
# frame in the fat build; absent affordance in the thin build). The owner must
# upload a sample frame and set this before the thin client can fetch one.
VITE_SAMPLE_FRAME_URL=

# ── Decode / solver feature flags (VITE_*) ───────────────────────────────────
# RAW decoder arm. DEFAULT ON (rawler). Set to 0 (or false) to select the
# libraw cold-path decoder.
VITE_DECODER_RAWLER=
# Greenfield Rust solver seam (desktop only). DEFAULT ON; only =0 disables it
# (the browser tier always stays on the legacy solver regardless).
VITE_SOLVER_GREENFIELD=
# g15u Gaia-only confirm-lane catalog. Confirm/adapter lane DEFAULT ON (opt out
# with =false); the browser solver tier is default OFF.
VITE_CATALOG_G15U=
# Multi-frame stacking. DEFAULT OFF; =1 (or true) enables.
VITE_STACK_ENABLED=
# CFA luma-parity fix. DEFAULT OFF (measured solve-harmful without a paired
# threshold recalibration — research flag).
VITE_CFA_LUMA_PARITY_FIX=
# Apply the sensor black level during decode (feature flag).
VITE_DECODE_APPLY_BLACK_LEVEL=
# Desktop auto-update toggle (feature flag).
VITE_DESKTOP_AUTOUPDATE=

# ── Atlas / catalog / starplates plumbing (VITE_*) ───────────────────────────
# Binary atlas format toggle (feature flag).
VITE_ATLAS_BINARY=
# Gaia atlas source toggle (feature flag).
VITE_ATLAS_GAIA=
# Starplates catalog plane toggle (feature flag).
VITE_STARPLATES=
# Starplates sync behavior (feature flag).
VITE_STARPLATES_SYNC=

# ── Intake / misc (VITE_*) ───────────────────────────────────────────────────
# Intake upload endpoint + label (config seam; unset = no upload affordance).
VITE_INTAKE_UPLOAD_URL=
VITE_INTAKE_UPLOAD_LABEL=
# SPCC QE-throughput correction toggle (feature flag).
VITE_SPCC_QE_THROUGHPUT=
# Synthetic dark producer (feature flag).
VITE_SYNTH_DARK_PRODUCER=
