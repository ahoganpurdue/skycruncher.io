*.cr2
*.nef
*.arw
*.fits
*.tiff
*.jpg
*.png
*.min.js
*.min.css

# Vite HMR Cache Files
vite.config.ts.timestamp-*.mjs

# Test Image Directories
src/data/Images/
public/demo/
Sample Files/

# Desktop test rail v0 — ephemeral webview-served assets (staged by
# tools/desktop_rail/run_rail.mjs, removed on exit; never commit).
public/__testrail_tmp/

# Widget Shelf showcase — local heavy report-class artifacts (baked fixed data,
# NOT registry widgets). Served locally at /showcase/*; the shelf renders an
# honest "not present" state on a box without them.
public/showcase/

# Legacy Test & Debug Archives
OLD TESTS/
test_results/
old_tests/
debug/

