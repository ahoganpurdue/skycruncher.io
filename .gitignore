# Build & Compiled Outputs
dist/
build/
out/
.vite/
target/
src-tauri/target/
src-tauri/gen/
src-tauri/binaries/

# tools/build/ holds a COMMITTED build-prep script (not build output). The
# generic build/ rule above ignores it; re-include only that one script while
# keeping any actual build output under tools/build/ ignored.
!tools/build/
tools/build/*
!tools/build/prep_demo_assets.mjs

# Ignore massive Rust artifacts but keep source code visible
**/target/
**/pkg/
**/check_output*.txt
**/check_errors*.txt
**/hyperparameter_results.json

# Dependencies & Static Tooling
node_modules/
venv/
vendor/
deps/
**/hyg-database/
.git/
.vscode/
.idea/
.zed/

# Lock Files — package-lock.json + Cargo.lock are now TRACKED for reproducible
# builds (R0-a restoration). Only the unused yarn/poetry locks stay ignored.
yarn.lock
poetry.lock

# Massive Static Data & Catalogs
public/atlas/sectors/*.json
public/atlas/sectors/
data/demo/
*.onnx
*.bin
*.hgt

# Vendored ONNX runtime binaries (recopy from node_modules/onnxruntime-web/dist)
public/wasm/

# Gaia source CSVs (atlas regeneration inputs — hundreds of MB; see tools/atlas/README.md)
gaia_*.csv

# One-off debug/scratch leftovers (root)
build_errors.txt
build_check.bat
debug_bg.js
fix_symbols.ps1
test_detail*.txt
test_final_debug.txt
tsc_errors_reorg*.txt
tools/atlas.rs.txt
src/engine/wasm_compute/build_errors.txt

