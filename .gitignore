.DS_Store
Thumbs.db

# Environment & Secrets
.env
.env.*
!.env.example

# Installer Binaries
*.exe
*.msi
*.dmg
*.app

# Deprecated Context — Hidden from AI Agent RAG
Legacy Resources/
Future Planning/

# Stale root-level files
tmp_old_solver.ts
test_arrow.ts

# Frozen documentation archive — one-shot audits/research kept on disk + in
# git history, but untracked so they don't clutter the live doc tree.
# See the docs taxonomy in docs/ROADMAP.md / CLAUDE.md.
docs/archive/

# LOCAL-only doc tier — strategy / personal / social docs that must NOT ship to
# a build-in-public GitHub push (grant strategy, event planning, community
# comparison surveys, brand-naming, competitive positioning, owner's
# whereabouts/contacts/money/calendar). Litmus + rationale in
# docs/00-README-STRUCTURE.md. Promotion local->public is a deliberate later
# step; unpublishing from git history is not, so IN DOUBT -> local.
docs/local/

# Overnight astrometry.net oracle — LOCAL machine config (points at the EXTERNAL
# solve-field binary + index dir) + any stray solve products. The wrapper
# (astrometry_truth.mjs) + the .example config ARE tracked; these are not.
tools/overnight/astrometry.local.json
tools/overnight/*.wcs
tools/overnight/*.solved
tools/overnight/*.axy
tools/overnight/*.corr
tools/overnight/*.rdls
tools/overnight/_work/

# Intake fetcher — the source links (your shared Drive/HTTP URLs) + the local
# HMAC signing secret are LOCAL. The fetcher + .example config ARE tracked.
tools/overnight/intake_sources.json
tools/overnight/intake_signing.key

# Tauri updater signing keys — the private key lives OUTSIDE the repo (K:/keys);
# this is defense-in-depth so a stray copy near the tree is never committed.
*.key
!*.key.pub

# Overnight Rig dashboard — Vite build output (source is tracked)
tools/overnight/dashboard/dist/

# Local OTel collector binary (config + scripts ARE tracked; output lands in
# test_results/otel/ which is already ignored via test_results/)
tools/telemetry/bin/

# Subagent worktree scratch (ephemeral, auto-managed by the harness)
.claude/worktrees/

# Obsidian editor state (owner-personal, never tracked)
.obsidian/
docs/.obsidian/
tools/theses/dashboard/ui/reports/
