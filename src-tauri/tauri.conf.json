{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SkyCruncher",
  "version": "1.3.0",
  "identifier": "io.skycruncher.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3005",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SkyCruncher — Scientific Pre-Processor",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: https://asset.localhost; worker-src 'self' blob:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/starplates/**/*"],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["English"]
      },
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZBOENGMDNEOTE1MjJCMDcKUldRSEsxS1JQZkNNK3E5dXVXRTcxZFMxQTJxQnJSdWtQQU5wdWRuQmhMTjA3UVZjTkx5OVVBbVMK",
      "endpoints": [
        "https://pub-ef3680a084e84b859bbfb15f3bbef338.r2.dev/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
